# Production environment — baked into the Vercel build at deploy time.
# These are public frontend URLs, not secrets — safe to commit.

# Backend REST API base (all /api/* routes)
VITE_API_URL=https://cp-sync-backend.onrender.com/api

# Google OAuth2 initiation URL (Spring Security OAuth2 endpoint)
VITE_AUTH_URL=https://cp-sync-backend.onrender.com/oauth2/authorization/google
